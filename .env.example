# .env.example

# WhatsApp Broadcast API Environment Variables

# WhatsApp account SID
WHATSAPP_ACCOUNT_SID=your_account_sid_here

# WhatsApp Auth Token
WHATSAPP_AUTH_TOKEN=your_auth_token_here

# WhatsApp phone number
WHATSAPP_PHONE_NUMBER=your_phone_number_here

# API endpoint
WHATSAPP_API_URL=https://api.whatsapp.com/v1/messages

# Additional optional settings
# TIMEOUT=30

# Set your preferred log level (debug, info, warn, error)
LOG_LEVEL=info
